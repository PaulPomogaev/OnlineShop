@{
    ViewData["Title"] = "Home Page";
}

<div class="container" style="margin-top: 30px;">
    <h2>Наши товары</h2>

    @if (ViewBag.Products != null)
    {
        foreach (var product in ViewBag.Products as List<OnlineShopWebApp.Models.Product>)
        {
            <div style="margin: 20px 0; padding: 15px; border: 1px solid #ddd; border-radius: 8px; background-color: #f9f9f9;">
                <p><strong>Id@(product.Id)</strong></p>
                <p>@product.Name</p>
                <p>@product.Cost руб.</p>
                @* Описание НЕ выводим — по условию задачи *@
                <hr />
            </div>
        }
    }
    else
    {
        <p>Нет товаров. Добавьте товары в файл Data/products.json</p>
    }

<div class="text-center">
    <h1 class="display-4">Welcome</h1>
    <p>Learn about <a href="https://learn.microsoft.com/aspnet/core">building Web apps with ASP.NET Core</a>.</p>
</div>
