@model List<OnlineShopWebApp.Models.ProductViewModel>
@{
    ViewData["Title"] = "Search";
}

<div class="row justify-content-end mb-4">
    <form asp-controller="Home" asp-action="Search" class="d-flex w-50" method="get">
        <input class="form-control me-2" type="search" placeholder="Поиск по названию..." name="query" value="@ViewContext.HttpContext.Request.Query["query"]" />
        <button class="btn btn-outline-success" type="submit">Искать</button>
    </form>
</div>

<div class="text-center text-uppercase text-success mb-5 mt-5">
    <h2 class="row-title">Товары, соответствующие запросу</h2>
</div>

<div class="row justify-content-center mt-3">
    @if (Model?.Count > 0)
    {
        @foreach (var product in Model)
        {
            @await Html.PartialAsync("ProductCard", product)
        }
    }
    else
    {
        <div class="text-center col-12">
            <h2>Ничего не найдено по запросу "@ViewContext.HttpContext.Request.Query["query"]"</h2>
        </div>
    }
</div>

<div class="text-center m-5">
    <a class="btn btn-outline-success" asp-controller="Home" asp-action="Index">
        Отобразить весь каталог товаров
    </a>
</div>