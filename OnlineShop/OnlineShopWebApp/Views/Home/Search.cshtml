@model List<Product>
@{
    ViewData["Title"] = "Search";
}

<div class="row justify-content-end mb-4">
    <form asp-controller="Home" asp-action="Search" class="d-flex w-50" method="get">
        <input class="form-control me-2" type="search" placeholder="Поиск по названию..." name="query" value="@ViewContext.HttpContext.Request.Query["query"]" />
        <button class="btn btn-outline-success" type="submit">Искать</button>
    </form>
</div>

<div class="text-center text-uppercase text-success mb-5 mt-5">
    <h2 class="row-title">Товары, соответствующие запросу</h2>
</div>

<div class="row justify-content-center mt-3">
    @if (Model?.Count > 0)
    {
        @foreach (var product in Model)
        {
            var photoPath = string.IsNullOrEmpty(product.PhotoPath)
                            ? "/img/whey-protein.jpg"
                            : "/" + product.PhotoPath.TrimStart('/');
           
            <div class="col-3 mb-3">
                <div class="card shadow">
                    <img class="card-img-top" src="@photoPath" alt="@product.Name" />
                    <div class="card-body text-center">
                        <a class="text-success" asp-controller="Product" asp-action="Index" asp-route-id="@product.Id">
                            <h5>@product.Name</h5>
                        </a>
                        <h2 class="text-danger">@product.Cost.ToString("C")</h2>
                        <a asp-controller="Cart" asp-action="Add" asp-route-productId="@product.Id" class="btn btn-success w-100">
                            Добавить в корзину
                        </a>
                        <a asp-controller="Favorite" asp-action="Add" asp-route-productId="@product.Id" class="btn btn-outline-primary w-100 mt-2">
                            В избранное
                        </a>
                    </div>
                </div>
            </div>
        }
    }
    else
    {
        <div class="text-center col-12">
            <h2>Ничего не найдено по запросу "@ViewContext.HttpContext.Request.Query["query"]"</h2>
        </div>
    }
</div>

<div class="text-center m-5">
    <a class="btn btn-outline-success" asp-controller="Home" asp-action="Index">
        Отобразить весь каталог товаров
    </a>
</div>