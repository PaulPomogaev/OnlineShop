@model OnlineShopWebApp.Models.ProductViewModel
@{
    ViewData["Title"] = Model != null ? $"Товар: {Model.Name}" : "Товар не найден";
}

<div class="row justify-content-center">
    @if (Model != null)
    {
        <div class="col-3 mb-3">
            <div class="card h-100">
                <img class="card-img-top" src="@Model.PhotoPath" alt="@Model.Name" id="mainProductImage" style="height: 300px; object-fit: cover;">
                                
                @if (Model.ImagePaths.Any())
                {
                    <div class="card-body">
                        <h6>Другие изображения:</h6>
                        <div class="row">
                            @foreach (var imagePath in Model.ImagePaths)
                            {
                                <div class="col-4 mb-2">
                                    <img src="@imagePath" alt="@Model.Name"
                                         class="img-thumbnail"
                                         style="cursor: pointer; height: 80px; object-fit: cover;"
                                         onclick="document.getElementById('mainProductImage').src='@imagePath'" />
                                </div>
                            }
                        </div>
                    </div>
                }

                <div class="card-body text-center">
                    <h4>@Model.Name</h4>
                    <h2 class="text-danger">@Model.Cost.ToString("C")</h2>

                    <a asp-controller="Cart" asp-action="Add" asp-route-productId="@Model.Id" class="btn btn-success">
                        Добавить в корзину
                    </a>
                    <a asp-controller="Favorite" asp-action="Add" asp-route-productId="@Model.Id" class="btn btn-outline-primary">
                        В избранное
                    </a>
                    <a asp-controller="Comparison" asp-action="Add" asp-route-productId="@Model.Id" class="btn btn-outline-secondary w-100 mt-2">
                        В сравнение
                    </a>
                </div>
            </div>
        </div>
        <div class="col-6 mb-3">
            <div class="card h-100">
                <div class="card-body">
                    <h5>Описание товара</h5>
                    <p class="card-text">@Model.Description</p>
                </div>
            </div>
        </div>
    }
    else
    {
        <div class="col-auto m-5">
            <h2>Такого товара не существует!</h2>
        </div>
    }
</div>

<div class="row justify-content-center">
    <div class="col-auto m-5">
        <a asp-controller="Home" asp-action="Index" class="btn btn-outline-success">Продолжить покупки</a>
    </div>
</div>
