@model LoginModel

@{
    ViewData["Title"] = "Авторизация пользователя";
}

<div class="text-center text-uppercase text-success mb-5 mt-5">
    <h2 class="row-title">Вход</h2>
</div>

<form method="post" asp-action="Login">
    <div class="row justify-content-center mt-3">
        <div class="col-6 mb-3">
            <p>
                <label class="form-label">Логин</label><br />
                <input class="form-control" placeholder="Ваш логин" required name="Login" />
            </p>
            <p>
                <label class="form-label">Пароль</label><br />
                <input class="form-control" placeholder="Ваш пароль" required name="Password" />
            </p>
            <p>
                <label class="form-check-label">Запомнить меня</label>
                <input class="form-check-input" type="checkbox" value="true" name="RememberMe" />
            </p>
        </div>
    </div>
    <div class="text-center m-3">
        <button class="btn btn-outline-success" type="submit">
            Войти
        </button>
    </div>
    <div class="text-center m-3">
        <a class="btn text-decoration-underline" asp-controller="Registration" asp-action="Index">
            Регистрация нового пользователя
        </a>
    </div>
</form>

