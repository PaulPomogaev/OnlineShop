@model OnlineShopWebApp.Models.ProductViewModel

<div class="col-3 mb-3">
    <div class="card shadow">
        
        @if (Model.ImagePaths.Any())
        {
            <div id="carousel-@Model.Id" class="carousel slide" data-bs-ride="carousel">
                <div class="carousel-inner">
                    
                    <div class="carousel-item active">
                        <img class="card-img-top" src="@Model.PhotoPath" alt="@Model.Name" style="height: 200px; object-fit: cover;" />
                    </div>
                    
                    @foreach (var imagePath in Model.ImagePaths)
                    {
                        <div class="carousel-item">
                            <img class="card-img-top" src="@imagePath" alt="@Model.Name" style="height: 200px; object-fit: cover;" />
                        </div>
                    }
                </div>
                @if (Model.ImagePaths.Count > 0)
                {
                    <button class="carousel-control-prev" type="button" data-bs-target="#carousel-@Model.Id" data-bs-slide="prev">
                        <span class="carousel-control-prev-icon"></span>
                    </button>
                    <button class="carousel-control-next" type="button" data-bs-target="#carousel-@Model.Id" data-bs-slide="next">
                        <span class="carousel-control-next-icon"></span>
                    </button>
                }
            </div>
        }
        else
        {
            <img class="card-img-top" src="@Model.PhotoPath" alt="@Model.Name" style="height: 200px; object-fit: cover;" />
        }

        <div class="card-body text-center">
            <a class="text-success" asp-controller="Product" asp-action="Index" asp-route-id="@Model.Id">
                <h5>@Model.Name</h5>
            </a>
            <h2 class="text-danger">@Model.Cost.ToString("C")</h2>
            <a asp-controller="Cart" asp-action="Add" asp-route-productId="@Model.Id" class="btn btn-success w-100">
                Добавить в корзину
            </a>
            <a asp-controller="Favorite" asp-action="Add" asp-route-productId="@Model.Id" class="btn btn-outline-primary w-100 mt-2">
                В избранное
            </a>
            <a asp-controller="Comparison"
               asp-action="Add"
               asp-route-productId="@Model.Id"
               class="btn btn-outline-info w-100 mt-2">
                В сравнение
            </a>
        </div>
    </div>
</div>