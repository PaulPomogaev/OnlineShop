@model dynamic

<a class="nav-link d-flex align-items-center"
   asp-area="UserProfile" asp-controller="UserProfile" asp-action="Index"
   title="Мой профиль">
    <img src="@Model.AvatarPath"
         alt="Аватар @Model.DisplayName"
         class="rounded-circle me-2"
         style="width: 32px; height: 32px; object-fit: cover; border: 1px solid #ddd;" />
    <span class="d-none d-md-inline">@Model.DisplayName</span>
</a>
