@model List<Product>
@{
    ViewData["Title"] = "Избранное";
}

<div class="text-center text-uppercase text-success mb-5 mt-5">
    <h2 class="row-title">Избранное</h2>
</div>

@if (Model != null && Model.Count > 0)
{
    <div class="row justify-content-center mt-3">
        @foreach (var product in Model)
        {
            <div class="col-3 mb-3">
                <div class="card shadow">
                    <img class="card-img-top" src=@product.PhotoPath alt="@product.Name" />
                    <div class="card-body text-center">
                        <a class="text-success" asp-controller="Product" asp-action="Index" asp-route-id="@product.Id">
                            <h5>@product.Name</h5>
                        </a>
                        <h2 class="text-danger">@product.Cost.ToString("C")</h2>
                        <hr />
                        <h6>@product.Description</h6>
                        <hr />
                        <a class="btn btn-success"
                           asp-controller="Cart"
                           asp-action="Add"
                           asp-route-productId="@product.Id">
                            Добавить в корзину
                        </a>
                        <form asp-controller="Favorite" asp-action="Delete" method="post" style="display:inline;">
                            <input type="hidden" name="productId" value="@product.Id" />
                            <button type="submit" class="btn btn-outline-danger mt-3">
                                Убрать из избранного
                            </button>
                        </form>
                    </div>
                </div>
            </div>
        }

        <div class="text-center mt-5">
            <form asp-controller="Favorite" asp-action="Clear" method="post" style="display:inline;">
                <button type="submit" class="btn btn-outline-danger">
                    Очистить список избранного
                </button>
            </form>
        </div>
    </div>
}
else
{
    <div class="text-center">
        <h2 class="row-title">В списке избранного нет товаров!</h2>
    </div>
}

<div class="text-center m-5">
    <a class="btn btn-outline-success"
       asp-controller="Home"
       asp-action="Index">
        Продолжить покупки
    </a>
</div>
