@model LoginModel

@{
    ViewData["Title"] = "Вход";
}

<div class="text-center text-uppercase text-success mb-5 mt-5">
    <h2 class="row-title">Вход</h2>
</div>

<form method="post" asp-action="Login">
    <div asp-validation-summary="All" class="text-danger mb-3"></div>
    <div class="row justify-content-center mt-3">
        <div class="col-6 mb-3">
            <div class="form-group">
                <label asp-for="Login" class="form-label"></label>
                <input asp-for="Login" class="form-control" placeholder="Ваш логин" />
                <span asp-validation-for="Login" class="text-danger"></span>
            </div>
            <div class="form-group mt-3">
                <label asp-for="Password" class="form-label"></label>
                <input asp-for="Password" class="form-control" placeholder="Ваш пароль" />
                <span asp-validation-for="Password" class="text-danger"></span>
            </div>
            <div class="form-check mt-3">
                <input asp-for="RememberMe" class="form-check-input" />
                <label asp-for="RememberMe" class="form-check-label"></label>
            </div>
        </div>
    </div>
    <div class="text-center m-3">
        <button class="btn btn-outline-success" type="submit">
            Войти
        </button>
    </div>
    <div class="text-center m-3">
        <a class="btn text-decoration-underline" asp-controller="Account" asp-action="Register">
            Регистрация нового пользователя
        </a>
    </div>
</form>