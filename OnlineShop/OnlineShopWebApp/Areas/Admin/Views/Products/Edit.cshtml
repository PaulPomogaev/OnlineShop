@model ProductViewModel
@{
    ViewData["Title"] = "Редактирование товара";
}

<div class="row mt-3">
    @await Html.PartialAsync("AdminMenu")
    <div class="col-9 mb-3">
        <div class="text-center text-uppercase text-success mb-5 mt-5">
            <h2 class="row-title">Редактирование товара</h2>
        </div>

        <form method="post" asp-area="Admin" asp-controller="Products" asp-action="Edit" enctype="multipart/form-data">
            <div asp-validation-summary="All" class="text-danger fw-bold text-uppercase mb-3"></div>
            <div class="row justify-content-center mt-3">
                <div class="col-6 mb-3">
                    <input type="hidden" asp-for="Id" />
                    <div class="mb-3">
                        <label asp-for="Name" class="form-label"></label>
                        <input asp-for="Name" class="form-control" />
                        <span asp-validation-for="Name" class="text-danger"></span>
                    </div>

                    <div class="mb-3">
                        <label asp-for="Cost" class="form-label"></label>
                        <input asp-for="Cost" type="number" step="0.01" class="form-control" />
                        <span asp-validation-for="Cost" class="text-danger"></span>
                    </div>

                    <div class="mb-3">
                        <label asp-for="Description" class="form-label"></label>
                        <textarea asp-for="Description" class="form-control" rows="4"></textarea>
                        <span asp-validation-for="Description" class="text-danger"></span>
                    </div>

                    <div class="mb-3">
                        <label asp-for="UploadedFile" class="form-label">Загрузить новое изображение</label>
                        <input asp-for="UploadedFile" type="file" class="form-control" />
                        <span asp-validation-for="UploadedFile" class="text-danger"></span>
                    </div>
                    @if (!string.IsNullOrEmpty(Model.PhotoPath))
                    {
                        <div class="mb-3">
                            <label>Текущее изображение:</label>
                            <br />
                            <img src="@Model.PhotoPath" alt="Текущее изображение" style="max-width: 200px; max-height: 200px;" />
                        </div>
                    }
                </div>
            </div>
            <div class="text-center m-3">
                <button class="btn btn-outline-success" type="submit">
                    Редактировать
                </button>
            </div>
        </form>
    </div>
</div>