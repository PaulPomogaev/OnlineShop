@model UserRole
@{
    ViewData["Title"] = "Права доступа";
}

<div class="row mt-3">
    @await Html.PartialAsync("AdminMenu")
    <div class="col-9 mb-3">
        <div class="text-center text-uppercase text-success mb-5 mt-5">
            <h2 class="row-title">Права доступа для пользователя @Model.UserLogin</h2>
        </div>
        <form method="post" asp-area="Admin" asp-controller="Users" asp-action="AssignRoles">
            <div asp-validation-summary="All" class="text-danger fw-bold text-uppercase mb-3"></div>
            <input type="hidden" asp-for="UserId" />
            <div class="row justify-content-center mt-3">
                <div class="col-6 mb-3">
                    <h5>Доступные роли:</h5>
                    @foreach (var role in Model.AllRoles)
                    {
                        <div class="form-check">
                            <input type="checkbox" name="UserRoleIds" value="@role.Id"
                            @(Model.UserRoleIds.Contains(role.Id) ? "checked" : "") />
                            <label class="form-check-label">@role.Name</label>
                        </div>
                    }
                </div>
            </div>
            <div class="text-center m-3">
                <button class="btn btn-outline-success" type="submit">
                    Сохранить права
                </button>
            </div>
        </form>
    </div>
</div>