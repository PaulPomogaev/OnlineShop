@model ChangePassword
@{
    ViewData["Title"] = "Смена пароля";
}

<div class="row mt-3">
    @await Html.PartialAsync("AdminMenu")
    <div class="col-9 mb-3">
        <div class="text-center text-uppercase text-success mb-5 mt-5">
            <h2 class="row-title">Смена пароля для пользователя</h2>
        </div>
        <form method="post" asp-area="Admin" asp-controller="Users" asp-action="ChangePassword">
            <div asp-validation-summary="All" class="text-danger fw-bold text-uppercase mb-3"></div>
            <input type="hidden" asp-for="UserId" />
            <div class="row justify-content-center mt-3">
                <div class="col-6 mb-3">
                    <div class="mb-3">
                        <label asp-for="OldPassword" class="form-label"></label>
                        <input asp-for="OldPassword" type="password" class="form-control" />
                        <span asp-validation-for="OldPassword" class="text-danger"></span>
                    </div>
                    <div class="mb-3">
                        <label asp-for="NewPassword" class="form-label"></label>
                        <input asp-for="NewPassword" type="password" class="form-control" />
                        <span asp-validation-for="NewPassword" class="text-danger"></span>
                    </div>
                    <div class="mb-3">
                        <label asp-for="ConfirmPassword" class="form-label"></label>
                        <input asp-for="ConfirmPassword" type="password" class="form-control" />
                        <span asp-validation-for="ConfirmPassword" class="text-danger"></span>
                    </div>
                </div>
            </div>
            <div class="text-center m-3">
                <button class="btn btn-outline-success" type="submit">
                    Изменить пароль
                </button>
            </div>
        </form>
    </div>
</div>