@model UserDetails
@{
    ViewData["Title"] = $"Пользователь {Model.Login}";
}

<div class="row mt-3">
    @await Html.PartialAsync("AdminMenu")
    <div class="col-9 mb-3">
        <div class="text-center text-uppercase text-success mb-5 mt-5">
            <h2 class="row-title">Пользователь @Model.Login</h2>
        </div>
        <div class="card shadow">
            <div class="card-body">
                <h5 class="card-title">Информация о пользователе</h5>
                <div class="row">
                    <div class="col-md-6">
                        <p><strong>ID:</strong> @Model.Id</p>
                        <p><strong>Email (логин):</strong> @Model.Login</p>
                        <p><strong>Имя:</strong> @Model.FirstName</p>
                        <p><strong>Фамилия:</strong> @Model.LastName</p>
                        <p><strong>Телефон:</strong> @Model.PhoneNumber</p>
                        <p><strong>Дата регистрации:</strong> @Model.CreatedDate</p>
                    </div>
                    <div class="col-md-6">
                        <p><strong>Роль:</strong>
                            @if (Model.RoleNames.Any())
                            {
                                @string.Join(", ", Model.RoleNames)
                            }
                            else
                            {
                                    <span>Нет ролей</span>
                            }
                        </p>
                    </div>
                </div>
                
                <div class="text-end">
                    <div class="btn-group">
                        <button type="button" class="btn btn-outline-success dropdown-toggle" data-bs-toggle="dropdown" aria-expanded="false">
                            Действия
                        </button>
                        <ul class="dropdown-menu">
                            <li><a class="dropdown-item" asp-action="ChangePassword" asp-route-id="@Model.Id">Смена пароля</a></li>
                            <li><a class="dropdown-item" asp-action="Edit" asp-route-id="@Model.Id">Редактирование данных</a></li>
                            <li><a class="dropdown-item" asp-action="AssignRoles" asp-route-id="@Model.Id">Права доступа</a></li>
                            <li><hr class="dropdown-divider"></li>
                            <li>
                                <a class="dropdown-item text-danger" href="#" data-bs-toggle="modal" data-bs-target="#deleteUserModal">
                                    Удалить пользователя
                                </a>
                            </li>
                        </ul>
                    </div>
                </div>
            </div>
        </div>
        <div class="modal fade" id="deleteUserModal" tabindex="-1" aria-labelledby="deleteUserModalLabel" aria-hidden="true">
            <div class="modal-dialog">
                <div class="modal-content">
                    <div class="modal-header">
                        <h5 class="modal-title" id="deleteUserModalLabel">Удаление пользователя</h5>
                        <button type="button" class="btn-close" data-bs-dismiss="modal" aria-label="Close"></button>
                    </div>
                    <div class="modal-body">
                        Вы действительно хотите удалить пользователя "<strong>@Model.Login</strong>"?
                    </div>
                    <div class="modal-footer">
                        <form method="post" asp-area="Admin" asp-controller="Users" asp-action="Delete" asp-route-id="@Model.Id">
                            <button type="submit" class="btn btn-outline-danger">Удалить</button>
                        </form>
                        <button type="button" class="btn btn-outline-success" data-bs-dismiss="modal">Отмена</button>
                    </div>
                </div>
            </div>
        </div>
        <div class="text-center mt-5">
            <a class="btn btn-outline-secondary" asp-action="Index">Назад к списку</a>
        </div>
    </div>
</div>